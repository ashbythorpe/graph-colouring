{
	"version": 3,
	"configurePresets": [
		{
			"name": "dev",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Debug",
				"CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
			}
		},
		{
			"name": "release",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_CXX_FLAGS": "-march=native"
			}
		},
		{
			"name": "profile",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "RelWithDebInfo",
				"CMAKE_CXX_FLAGS": "-fno-omit-frame-pointer"
			}
		},
		{
			"name": "benchmark-memory",
			"cacheVariables": {
				"CMAKE_BUILD_TYPE": "Release",
				"CMAKE_CXX_FLAGS": "-march=native",
				"BENCHMARK_MEMORY": "ON"
			}
		}
	]
}
